# ==============================================
# Analytics Configuration
# ==============================================
# Set these to enable analytics tracking.
# All analytics tools are FREE. Scripts load only when IDs are provided.
# See docs/ANALYTICS.md for full documentation.

# Umami Analytics (https://umami.is)
# Get your Website ID from the Umami Cloud dashboard
PUBLIC_UMAMI_WEBSITE_ID=
PUBLIC_UMAMI_SCRIPT_URL=https://cloud.umami.is/script.js

# Microsoft Clarity (https://clarity.microsoft.com)
# Get your Project ID from the Clarity dashboard
PUBLIC_CLARITY_PROJECT_ID=

# Google Search Console verification
# Get from GSC > Settings > Ownership verification > HTML tag
PUBLIC_GOOGLE_SITE_VERIFICATION=

# Bing Webmaster Tools verification
# Get from Bing Webmaster > Settings > Ownership verification
PUBLIC_BING_SITE_VERIFICATION=

# ==============================================
# Contact Form (Google Forms)
# ==============================================
# Create a Google Form with: Name, Email, Reason, Subject, Message
# Get entry IDs by inspecting the form's HTML source
# Form only loads when URL is provided.

PUBLIC_GOOGLE_FORM_URL=
PUBLIC_GOOGLE_FORM_ENTRY_NAME=
PUBLIC_GOOGLE_FORM_ENTRY_EMAIL=
PUBLIC_GOOGLE_FORM_ENTRY_REASON=
PUBLIC_GOOGLE_FORM_ENTRY_SUBJECT=
PUBLIC_GOOGLE_FORM_ENTRY_MESSAGE=
