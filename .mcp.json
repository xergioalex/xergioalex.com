{
  "mcpServers": {
    "chrome-devtools": {
      "type": "stdio",
      "command": "npx",
      "args": [
        "-y",
        "chrome-devtools-mcp@latest",
        "--headless=true",
        "--isolated=true",
        "--executablePath=/app/scripts/chromium-mcp.sh"
      ],
      "env": {}
    },
    "playwright": {
      "type": "sse",
      "url": "http://playwright-mcp:8931/sse"
    }
  }
}