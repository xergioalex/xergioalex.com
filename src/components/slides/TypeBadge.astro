---
import type { Language } from '@/lib/i18n';
import { getTranslations } from '@/lib/translations';

interface Props {
  type: 'internal' | 'external-link' | 'external-embed';
  lang: Language;
}

const { type, lang } = Astro.props;
const t = getTranslations(lang);

const badgeKey =
  type === 'internal'
    ? 'internal'
    : type === 'external-link'
      ? 'externalLink'
      : 'externalEmbed';

const label = t.slides.typeBadge[badgeKey];

const colorClasses: Record<string, string> = {
  internal:
    'bg-emerald-100 text-emerald-800 dark:bg-emerald-900/40 dark:text-emerald-300',
  'external-link':
    'bg-blue-100 text-blue-800 dark:bg-blue-900/40 dark:text-blue-300',
  'external-embed':
    'bg-purple-100 text-purple-800 dark:bg-purple-900/40 dark:text-purple-300',
};
---

<span class={`inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium ${colorClasses[type]}`}>
  {label}
</span>
