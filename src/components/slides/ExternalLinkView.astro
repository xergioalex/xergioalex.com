---
import type { CollectionEntry } from 'astro:content';
import JsonLd from '@/components/JsonLd.astro';
import MainLayout from '@/layouts/MainLayout.astro';
import { getUrlPrefix, type Language } from '@/lib/i18n';
import { isDraftDeck } from '@/lib/slides';
import { getTranslations } from '@/lib/translations';

interface Props {
  deck: CollectionEntry<'slides'>;
  lang: Language;
  jsonLd?: Record<string, unknown>;
}

const { deck, lang, jsonLd } = Astro.props;
const t = getTranslations(lang);
const prefix = getUrlPrefix(lang);

const data = deck.data as CollectionEntry<'slides'>['data'] & {
  type: 'external-link';
  externalUrl: string;
  provider?: string;
};

const provider = data.provider || 'external';
const providerLabel =
  provider.charAt(0).toUpperCase() + provider.slice(1).replace(/-/g, ' ');
const ctaText = t.slides.externalLink.openCta.replace(
  '{provider}',
  providerLabel
);
const isDraft = isDraftDeck(deck);
---

<MainLayout lang={lang} title={data.title} description={data.description} image={data.heroImage}>
  {jsonLd && (
    <Fragment slot="head">
      <JsonLd data={jsonLd} />
    </Fragment>
  )}
  <div class="max-w-4xl mx-auto px-4 py-12 sm:px-6 lg:px-8">
    {data.heroImage && (
      <div class="mb-8 rounded-xl overflow-hidden">
        <img
          src={data.heroImage}
          alt={data.title}
          width={1200}
          height={675}
          class="w-full h-auto object-cover"
          loading="eager"
        />
      </div>
    )}

    {isDraft && (
      <div class="mb-4">
        <span class="inline-flex items-center rounded-full bg-purple-100 px-3 py-1 text-xs font-bold uppercase tracking-wide text-purple-800 dark:bg-purple-900/40 dark:text-purple-200">
          {t.draftBadge}
        </span>
      </div>
    )}

    <h1 class="text-3xl sm:text-4xl font-bold text-gray-900 dark:text-gray-100 mb-4">
      {data.title}
    </h1>

    <p class="text-lg text-gray-600 dark:text-gray-300 mb-6">
      {data.description}
    </p>

    {data.eventName && (
      <div class="flex items-center gap-2 text-sm text-gray-600 dark:text-gray-300 mb-8">
        <span>{data.eventName}</span>
        {data.eventDate && (
          <>
            <span>·</span>
            <time datetime={data.eventDate.toISOString().split('T')[0]}>
              {data.eventDate.toLocaleDateString(lang === 'es' ? 'es-CO' : 'en-US', {
                year: 'numeric',
                month: 'long',
                day: 'numeric',
              })}
            </time>
          </>
        )}
        {data.eventUrl && (
          <>
            <span>·</span>
            <a
              href={data.eventUrl}
              target="_blank"
              rel="noopener noreferrer"
              class="text-secondary hover:underline"
            >
              Event page ↗
            </a>
          </>
        )}
      </div>
    )}

    {deck.body && deck.body.trim() && (
      <div class="prose dark:prose-invert max-w-none mb-8">
        <Fragment set:html={deck.body} />
      </div>
    )}

    <div class="flex flex-col sm:flex-row gap-4">
      <a
        href={data.externalUrl}
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center justify-center px-6 py-3 rounded-lg bg-secondary text-white font-medium hover:opacity-90 transition-opacity"
      >
        {ctaText} →
      </a>
      <a
        href={`${prefix}/slides`}
        class="inline-flex items-center justify-center px-6 py-3 rounded-lg border border-gray-300 dark:border-gray-600 text-gray-700 dark:text-gray-300 font-medium hover:bg-gray-50 dark:hover:bg-gray-800 transition-colors"
      >
        {t.slides.externalLink.backToCatalog}
      </a>
    </div>
  </div>
</MainLayout>
