---
import { getCollection } from 'astro:content';
import BlogCard from '@/components/blog/BlogCard.svelte';
import { getBlogPosts } from '@/lib/blog';
import { getUrlPrefix, type Language } from '@/lib/i18n';
import { getTranslations } from '@/lib/translations';

interface Props {
  lang?: Language;
  grouped?: boolean;
  surface?: 'default' | 'alt';
}

const { lang = 'en', grouped = false, surface = 'default' } = Astro.props;
const t = getTranslations(lang);
const prefix = getUrlPrefix(lang);
const sectionSpacing = grouped
  ? 'pt-6 sm:pt-8 lg:pt-10 pb-12 sm:pb-16 lg:pb-20'
  : 'py-16';
const sectionSurface =
  surface === 'alt'
    ? 'bg-gray-50 dark:bg-gray-800'
    : 'bg-white dark:bg-gray-900';

const blogResult = await getBlogPosts({ lang, tag: 'talks', pageSize: 2 });
const posts = blogResult.postsResult;

const allTags = await getCollection('tags');
const topicTagNames = allTags
  .filter(
    (tag) => tag.data.tier === 'secondary' || tag.data.tier === 'subtopic'
  )
  .map((tag) => tag.data.name);
---

<section class={`${sectionSpacing} ${sectionSurface} transition-colors duration-300`}>
  <div class="main-container">
    <h2
      class="text-2xl sm:text-3xl md:text-4xl font-bold text-gray-900 dark:text-white mb-8"
    >
      {t.homeSections.techTalksPostsTitle}
    </h2>
    {posts.length > 0 ? (
      <>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
          {
            posts.map((post) => (
              <BlogCard
                client:visible
                {post}
                {lang}
                heroWebpExists={(post as any).heroWebpExists ?? false}
                {topicTagNames}
              />
            ))
          }
        </div>
        <div class="mt-8 text-center">
          <a
            href={`${prefix}/tech-talks#timeline`}
            class="inline-block border-b-2 border-secondary text-gray-900 dark:text-white font-bold text-base sm:text-lg hover:text-secondary transition"
          >
            {t.homeSections.techTalksPostsViewAll} &rarr;
          </a>
        </div>
      </>
    ) : (
      <p class="text-gray-600 dark:text-gray-300 text-center py-8">
        {t.homeSections.techTalksPostsEmpty}
      </p>
    )}
  </div>
</section>
