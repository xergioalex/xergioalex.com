---
import { getCollection } from 'astro:content';
import EntrepreneurTimeline from '@/components/entrepreneur/EntrepreneurTimeline.svelte';
import JsonLd from '@/components/JsonLd.astro';
import PageHero from '@/components/pages/PageHero.astro';
import PageSection from '@/components/pages/PageSection.astro';
import ScrollToTimeline from '@/components/pages/ScrollToTimeline.svelte';
import TimelineItem from '@/components/pages/TimelineItem.astro';
import MainLayout from '@/layouts/MainLayout.astro';
import { getBlogPosts } from '@/lib/blog';
import { getUrlPrefix, type Language } from '@/lib/i18n';
import { getTranslations } from '@/lib/translations';

interface Props {
  lang: Language;
}

const { lang } = Astro.props;
const t = getTranslations(lang);
const prefix = getUrlPrefix(lang);
const siteUrl = Astro.site?.href?.replace(/\/$/, '') ?? '';
const contactCtaHref = `${prefix}/contact?${new URLSearchParams({
  topic: 'collaboration',
  subject: t.contactPage.prefillSubjects.startupCollaboration,
}).toString()}`;

const { postsResult: posts } = await getBlogPosts({
  lang,
  tag: 'entrepreneur',
  pageSize: 100,
});

const allTags = await getCollection('tags');
const topicTagNames = allTags
  .filter(
    (tag) => tag.data.tier === 'secondary' || tag.data.tier === 'subtopic'
  )
  .map((tag) => tag.data.name);

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    {
      '@type': 'ListItem',
      position: 1,
      name: 'Home',
      item: `${siteUrl}${prefix}/`,
    },
    {
      '@type': 'ListItem',
      position: 2,
      name: t.entrepreneurPage.title,
      item: `${siteUrl}${prefix}/entrepreneur`,
    },
  ],
};
---

<MainLayout lang={lang} title={t.entrepreneurPage.title} description={t.entrepreneurPage.description}>
  <Fragment slot="head">
    <JsonLd data={breadcrumbSchema} />
  </Fragment>
  <PageHero
    title={t.entrepreneurPage.title}
    subtitle={t.entrepreneurPage.subtitle}
    description={t.entrepreneurPage.heroDescription}
  />

  <PageSection title={t.entrepreneurPage.journeyTitle} description={t.entrepreneurPage.journeyText} />

  <PageSection title={t.entrepreneurPage.venturesTitle} background="gray">
    <ol class="relative">
      {t.entrepreneurPage.ventures.map((venture, index) => (
        <TimelineItem
          title={venture.title}
          description={venture.description}
          period={venture.period}
          isLast={index === t.entrepreneurPage.ventures.length - 1}
        />
      ))}
    </ol>
  </PageSection>

  <PageSection title={t.entrepreneurPage.philosophyTitle} description={t.entrepreneurPage.philosophyText} />

  <PageSection title={t.entrepreneurPage.lessonsTitle} background="gray">
    <ol class="space-y-4">
      {t.entrepreneurPage.lessons.map((lesson, i) => (
        <li class="flex gap-4 items-start">
          <span class="flex-shrink-0 w-8 h-8 rounded-full bg-secondary/10 text-secondary flex items-center justify-center font-bold text-sm">{i + 1}</span>
          <p class="text-gray-600 dark:text-gray-300">{lesson}</p>
        </li>
      ))}
    </ol>
  </PageSection>

  <section class="py-16 md:py-20 bg-white dark:bg-gray-900 transition-colors duration-300">
    <div class="main-container text-center">
      <a href={contactCtaHref} class="inline-block px-8 py-3 bg-secondary text-white font-semibold rounded-full hover:bg-secondary/90 transition-colors">
        {t.contactPage.title}
      </a>
    </div>
  </section>

  <section id="timeline" class="py-12 md:py-16">
    <div class="main-container">
      <h2 class="text-2xl sm:text-3xl md:text-4xl font-bold text-gray-900 dark:text-white mb-8">
        {t.entrepreneurPage.timelineTitle}
      </h2>
      <EntrepreneurTimeline client:visible posts={posts} lang={lang} {topicTagNames} />
    </div>
  </section>

  <ScrollToTimeline client:load lang={lang} targetLabel={t.entrepreneurPage.timelineTitle} />
</MainLayout>
