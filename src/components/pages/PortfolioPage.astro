---
import { getCollection } from 'astro:content';
import TagTimelineInfiniteScroll from '@/components/blog/TagTimelineInfiniteScroll.svelte';
import JsonLd from '@/components/JsonLd.astro';
import HighlightCard from '@/components/pages/HighlightCard.astro';
import PageHero from '@/components/pages/PageHero.astro';
import PageSection from '@/components/pages/PageSection.astro';
import ScrollToTimeline from '@/components/pages/ScrollToTimeline.svelte';
import MainLayout from '@/layouts/MainLayout.astro';
import { getTimelineIndex } from '@/lib/blog';
import { BLOG_PAGE_SIZE } from '@/lib/constances';
import { getUrlPrefix, type Language } from '@/lib/i18n';
import { getTranslations } from '@/lib/translations';

interface Props {
  lang: Language;
}

const { lang } = Astro.props;
const t = getTranslations(lang);
const prefix = getUrlPrefix(lang);
const siteUrl = Astro.site?.href?.replace(/\/$/, '') ?? '';
const contactCtaHref = `${prefix}/contact?${new URLSearchParams({
  topic: 'project',
  subject: t.contactPage.prefillSubjects.projectCollaboration,
}).toString()}`;

const allPortfolioPosts = await getTimelineIndex('portfolio', lang);
const initialPosts = allPortfolioPosts.slice(0, BLOG_PAGE_SIZE);
const totalCount = allPortfolioPosts.length;
const timelineApiEndpoint = `/api/timeline/${lang}/portfolio.json`;

const allTags = await getCollection('tags');
const topicTagNames = allTags
  .filter(
    (tag) => tag.data.tier === 'secondary' || tag.data.tier === 'subtopic'
  )
  .map((tag) => tag.data.name);

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    {
      '@type': 'ListItem',
      position: 1,
      name: 'Home',
      item: `${siteUrl}${prefix}/`,
    },
    {
      '@type': 'ListItem',
      position: 2,
      name: t.portfolioPage.title,
      item: `${siteUrl}${prefix}/portfolio`,
    },
  ],
};
---

<MainLayout
  lang={lang}
  title={t.portfolioPage.title}
  description={t.portfolioPage.description}
  keywords={lang === 'en'
    ? ['XergioAleX portfolio', 'software projects showcase', 'web development projects', 'open source developer', 'Sergio Florez projects', 'tech side projects']
    : ['portafolio XergioAleX', 'proyectos de software', 'proyectos desarrollo web', 'desarrollador open source', 'proyectos Sergio Florez', 'proyectos tecnológicos personales']}
>
  <Fragment slot="head">
    <JsonLd data={breadcrumbSchema} />
  </Fragment>
  <PageHero
    title={t.portfolioPage.title}
    subtitle={t.portfolioPage.subtitle}
    description={t.portfolioPage.heroDescription}
    image="/images/ia.png"
  />

  <PageSection title={t.portfolioPage.journeyTitle} description={t.portfolioPage.journeyText} />

  <PageSection title={t.portfolioPage.philosophyTitle} description={t.portfolioPage.philosophyText} background="gray" />

  <PageSection title={t.portfolioPage.areasTitle}>
    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
      {t.portfolioPage.areas.map((area) => (
        <HighlightCard title={area.title} description={area.description} icon={area.icon} />
      ))}
    </div>
  </PageSection>

  <PageSection title={t.portfolioPage.currentTitle} description={t.portfolioPage.currentText} background="gray">
    <div class="text-center mt-8 md:mt-10 flex flex-wrap items-center justify-center gap-4">
      <a
        href={t.portfolioPage.ctaLink}
        target="_blank"
        rel="noopener noreferrer"
        class="inline-block px-8 py-4 bg-secondary text-white font-bold text-lg rounded-xl hover:bg-secondary/90 hover:-translate-y-1 transition-all duration-300 shadow-lg hover:shadow-xl"
      >
        {t.portfolioPage.ctaText}
      </a>
      <a
        href={contactCtaHref}
        class="inline-block px-8 py-4 border-2 border-secondary text-secondary font-bold text-lg rounded-xl hover:bg-secondary/10 transition-colors duration-300"
      >
        {t.contactPage.title}
      </a>
    </div>
  </PageSection>

  <section id="timeline" class="py-12 md:py-16">
    <div class="main-container">
      <h2 class="text-2xl sm:text-3xl md:text-4xl font-bold text-gray-900 dark:text-white mb-8">
        {t.portfolioPage.timelineTitle}
      </h2>
      <TagTimelineInfiniteScroll
        client:visible
        {initialPosts}
        {totalCount}
        apiEndpoint={timelineApiEndpoint}
        {lang}
        {topicTagNames}
        pageSize={BLOG_PAGE_SIZE}
        pageName="portfolio"
        emptyStateMessage={t.portfolioPage.emptyState}
      />
    </div>
  </section>

  <ScrollToTimeline client:load lang={lang} targetLabel={t.portfolioPage.timelineTitle} />
</MainLayout>
