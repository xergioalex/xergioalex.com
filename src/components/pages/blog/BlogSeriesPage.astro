---
import { getCollection } from 'astro:content';

import SeriesInfiniteScroll from '@/components/blog/SeriesInfiniteScroll.svelte';
import MainLayout from '@/layouts/MainLayout.astro';
import { getSeriesTimelineIndex } from '@/lib/blog';
import { BLOG_PAGE_SIZE } from '@/lib/constances';
import { getUrlPrefix, type Language } from '@/lib/i18n';
import { getTranslations } from '@/lib/translations';

interface Props {
  lang: Language;
  slug: string;
}

const { lang, slug } = Astro.props;
const t = getTranslations(lang);
const prefix = getUrlPrefix(lang);

const allSeries = await getCollection('series');
const series = allSeries.find((s) => s.id === slug);
if (!series) {
  return Astro.redirect(`${prefix}/blog/`);
}

const allPosts = await getSeriesTimelineIndex(slug, lang);
const initialPosts = allPosts.slice(0, BLOG_PAGE_SIZE);
const totalCount = allPosts.length;
const seriesApiEndpoint = `/api/series/${lang}/${slug}.json`;
---

<MainLayout
  lang={lang}
  title={`${series.data.title} — ${t.seriesPage.title}`}
  description={series.data.description || t.seriesPage.emptyState}
>
  <section class="py-8 md:py-12">
    <!-- Breadcrumb navigation -->
    <nav class="max-w-3xl mx-auto px-4 mb-6" aria-label="Breadcrumb">
      <ol class="flex items-center gap-2 text-sm text-gray-600 dark:text-gray-300">
        <li>
          <a href={`${prefix}/blog/`} class="hover:text-blue-600 dark:hover:text-blue-400 transition-colors">
            {t.nav.blog}
          </a>
        </li>
        <li aria-hidden="true" class="text-gray-400 dark:text-gray-500">/</li>
        <li>
          <a href={`${prefix}/blog/series/`} class="hover:text-blue-600 dark:hover:text-blue-400 transition-colors">
            {t.seriesPage.breadcrumb}
          </a>
        </li>
        <li aria-hidden="true" class="text-gray-400 dark:text-gray-500">/</li>
        <li aria-current="page" class="font-medium text-gray-900 dark:text-white truncate">
          {series.data.title}
        </li>
      </ol>
    </nav>

    <div class="px-4">
      <SeriesInfiniteScroll
        client:visible
        {initialPosts}
        {totalCount}
        apiEndpoint={seriesApiEndpoint}
        {lang}
        seriesTitle={series.data.title}
        seriesDescription={series.data.description || ''}
        pageSize={BLOG_PAGE_SIZE}
        emptyStateMessage={t.seriesPage.emptyState}
      />
    </div>

    <!-- Back to series listing -->
    <div class="max-w-3xl mx-auto px-4 mt-8 flex gap-4">
      <a
        href={`${prefix}/blog/series/`}
        class="inline-flex items-center gap-2 text-sm text-gray-600 dark:text-gray-300 hover:text-blue-600 dark:hover:text-blue-400 transition-colors"
      >
        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7" />
        </svg>
        {t.seriesPage.backToSeries}
      </a>
      <a
        href={`${prefix}/blog/`}
        class="inline-flex items-center gap-2 text-sm text-gray-600 dark:text-gray-300 hover:text-blue-600 dark:hover:text-blue-400 transition-colors"
      >
        {t.seriesPage.backToBlog}
      </a>
    </div>
  </section>
</MainLayout>
