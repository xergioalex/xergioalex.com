---
import type { CollectionEntry } from 'astro:content';
import { render } from 'astro:content';
import AuthorBioCard from '@/components/blog/AuthorBioCard.astro';
import BlogImageLightbox from '@/components/blog/BlogImageLightbox.svelte';
import BlogPostHeader from '@/components/blog/BlogPostHeader.astro';
import NewsletterForm from '@/components/blog/NewsletterForm.svelte';
import RelatedArticles from '@/components/blog/RelatedArticles.astro';
import SeriesIndicator from '@/components/blog/SeriesIndicator.svelte';
import SeriesNavigation from '@/components/blog/SeriesNavigation.astro';
import ShareButtons from '@/components/blog/ShareButtons.astro';
import TypewriterDemo from '@/components/blog/TypewriterDemo.astro';
import JsonLd from '@/components/JsonLd.astro';
import MainLayout from '@/layouts/MainLayout.astro';
import {
  getReadingTimeFromContent,
  getRelatedPosts,
  getSeriesNavigation,
  getWordCount,
  groupPostTags,
  isScheduledPost,
} from '@/lib/blog';
import { NEWSLETTER } from '@/lib/constances';
import type { Language } from '@/lib/i18n';
import { getUrlPrefix } from '@/lib/i18n';
import { getTranslations } from '@/lib/translations';

interface Props {
  lang: Language;
  post: CollectionEntry<'blog'>;
}

const { lang, post } = Astro.props;
const t = getTranslations(lang);
const prefix = getUrlPrefix(lang);

const { heroImage, pubDate, updatedDate, title, description, tags, keywords } =
  post.data;
const { Content } = await render(post);
const readingTimeMinutes = getReadingTimeFromContent(post.body ?? '');
const wordCount = getWordCount(post.body ?? '');
const { primaryTags, topicTags } = await groupPostTags(tags ?? []);
const isScheduled = isScheduledPost(post);
const seriesInfo = post.data.series
  ? await getSeriesNavigation(post.data.series, post.id, lang)
  : null;
const relatedPosts = await getRelatedPosts({
  currentPostId: post.id,
  tags: tags ?? [],
  lang,
  limit: 3,
});

const canonicalURL = new URL(Astro.url.pathname, Astro.site);
const articleSection = tags?.[0] ? t.tagNames[tags[0]] || tags[0] : 'Blog';
const blogPostingData = {
  '@context': 'https://schema.org',
  '@type': 'BlogPosting',
  headline: title,
  description: description,
  image: heroImage ? new URL(heroImage, Astro.site).href : undefined,
  datePublished: pubDate.toISOString(),
  dateModified: updatedDate ? updatedDate.toISOString() : pubDate.toISOString(),
  author: {
    '@type': 'Person',
    name: 'Sergio Alexander Florez Galeano',
    url: new URL('/about/', Astro.site).href,
    image: new URL('/images/profile.png', Astro.site).href,
  },
  publisher: {
    '@type': 'Person',
    name: 'Sergio Alexander Florez Galeano',
    url: new URL('/about/', Astro.site).href,
  },
  mainEntityOfPage: {
    '@type': 'WebPage',
    '@id': canonicalURL.href,
  },
  keywords: keywords && keywords.length > 0 ? keywords : tags || [],
  wordCount,
  timeRequired: `PT${readingTimeMinutes}M`,
  inLanguage: lang,
  articleSection,
  url: canonicalURL.href,
};

const homeUrl = prefix || '/';
const blogUrl = `${prefix}/blog/`;

const breadcrumbData = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    {
      '@type': 'ListItem',
      position: 1,
      name: t.nav.home,
      item: new URL(homeUrl, Astro.site).href,
    },
    {
      '@type': 'ListItem',
      position: 2,
      name: t.nav.blog,
      item: new URL(blogUrl, Astro.site).href,
    },
    {
      '@type': 'ListItem',
      position: 3,
      name: title,
      item: canonicalURL.href,
    },
  ],
};
---

<MainLayout lang={lang} title={title} description={description} image={heroImage} keywords={keywords} ogType="article">
  <Fragment slot="head">
    <JsonLd data={blogPostingData} />
    <JsonLd data={breadcrumbData} />
    <meta property="article:published_time" content={pubDate.toISOString()} />
    <meta property="article:modified_time" content={(updatedDate ?? pubDate).toISOString()} />
    <meta property="article:author" content={new URL('/about/', Astro.site).href} />
    <meta property="article:section" content={articleSection} />
    {tags?.map((tag) => <meta property="article:tag" content={tag} />)}
  </Fragment>
  <div class="reading-progress" data-reading-progress aria-hidden="true"></div>
  <main class="main-container py-10 sm:py-12 lg:py-16">
    <article>
      <nav aria-label="Breadcrumb" class="mb-6 flex flex-wrap items-center gap-x-2 text-sm">
        <a href={homeUrl} class="font-semibold text-gray-600 transition-colors hover:text-blue-600 dark:text-gray-300 dark:hover:text-blue-400">{t.nav.home}</a>
        <span class="font-semibold text-gray-600 dark:text-gray-300 select-none" aria-hidden="true">/</span>
        <a href={blogUrl} class="font-semibold text-gray-600 transition-colors hover:text-blue-600 dark:text-gray-300 dark:hover:text-blue-400">{t.nav.blog}</a>
        <span class="font-semibold text-gray-600 dark:text-gray-300 select-none" aria-hidden="true">/</span>
        <span class="truncate font-normal text-gray-600 dark:text-gray-300" aria-current="page">{title}</span>
      </nav>
      {isScheduled && (
        <div class="mb-6 rounded-lg border border-amber-300 bg-amber-50 px-4 py-3 text-sm text-amber-800 dark:border-amber-700 dark:bg-amber-900/20 dark:text-amber-300">
          <strong>{t.scheduledBannerTitle}</strong> — {t.scheduledBannerMessage(pubDate.toLocaleDateString(t.dateLocale, { year: 'numeric', month: 'long', day: 'numeric', timeZone: 'UTC' }))}
        </div>
      )}
      <BlogPostHeader
        title={title}
        pubDate={pubDate}
        updatedDate={updatedDate}
        heroImage={heroImage}
        heroLayout={post.data.heroLayout}
        tags={primaryTags}
        topics={topicTags}
        lang={lang}
        readingTimeMinutes={readingTimeMinutes}
      />
      <div class="prose prose-lg prose-slate mx-auto max-w-4xl dark:prose-invert prose-headings:scroll-mt-24 prose-a:text-blue-600 dark:prose-a:text-blue-400 prose-img:block prose-img:mx-auto">
        <Content components={{ TypewriterDemo }} />
      </div>
      <section class="mx-auto mt-12 max-w-4xl space-y-8" aria-label={t.engagement.ctaTitle}>
        <AuthorBioCard lang={lang} />
        <ShareButtons lang={lang} title={title} url={canonicalURL.href} />
        <NewsletterForm
          client:visible
          lang={lang}
          formUrl={NEWSLETTER.googleForms.formUrl}
          entries={NEWSLETTER.googleForms.entries}
        />
      </section>
      {seriesInfo && <SeriesNavigation seriesInfo={seriesInfo} lang={lang} />}
      <RelatedArticles posts={relatedPosts} lang={lang} />
    </article>
    {seriesInfo && (
      <SeriesIndicator
        client:load
        lang={lang}
        currentChapter={seriesInfo.currentIndex + 1}
        totalChapters={seriesInfo.posts.length}
        seriesTitle={t.seriesNames[seriesInfo.name] || seriesInfo.title}
      />
    )}
    <BlogImageLightbox client:idle />
  </main>
</MainLayout>

<script>
  import { trackScrollDepth } from '@/lib/analytics';
  trackScrollDepth();
</script>

<script is:inline>
  (() => {
    const progressEl = document.querySelector('[data-reading-progress]');
    if (!(progressEl instanceof HTMLElement)) return;

    const supportsScrollTimeline =
      typeof CSS !== 'undefined' && CSS.supports('animation-timeline: scroll()');

    if (supportsScrollTimeline) return;

    progressEl.classList.add('reading-progress--js');

    let ticking = false;
    let frameId = 0;
    const maxScale = 1;

    const clamp = (value, min, max) => Math.min(max, Math.max(min, value));

    const updateProgress = () => {
      const root = document.documentElement;
      const scrollRange = root.scrollHeight - root.clientHeight;
      const ratio = scrollRange > 0 ? root.scrollTop / scrollRange : 0;
      progressEl.style.transform = `scaleX(${clamp(ratio, 0, maxScale)})`;
      ticking = false;
    };

    const scheduleUpdate = () => {
      if (ticking) return;
      ticking = true;
      frameId = window.requestAnimationFrame(updateProgress);
    };

    scheduleUpdate();
    window.addEventListener('scroll', scheduleUpdate, { passive: true });
    window.addEventListener('resize', scheduleUpdate, { passive: true });
    window.addEventListener('pagehide', () => {
      window.removeEventListener('scroll', scheduleUpdate);
      window.removeEventListener('resize', scheduleUpdate);
      if (frameId) {
        window.cancelAnimationFrame(frameId);
      }
    });
  })();
</script>

<style>
  .reading-progress {
    position: fixed;
    top: 0;
    left: 0;
    width: 0%;
    height: 3px;
    background: linear-gradient(to right, #2563eb, #3b82f6);
    z-index: 60;
    pointer-events: none;
    animation: reading-progress-fill linear;
    animation-timeline: scroll();
  }

  .reading-progress--js {
    width: 100%;
    transform: scaleX(0);
    transform-origin: left center;
    will-change: transform;
    animation: none;
  }

  @keyframes reading-progress-fill {
    from {
      width: 0%;
    }
    to {
      width: 100%;
    }
  }
</style>
