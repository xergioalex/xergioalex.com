---
import { getCollection } from 'astro:content';

import MainLayout from '@/layouts/MainLayout.astro';
import { getSeriesTimelineIndex } from '@/lib/blog';
import { getUrlPrefix, type Language } from '@/lib/i18n';
import { getTranslations } from '@/lib/translations';

interface Props {
  lang: Language;
}

const { lang } = Astro.props;
const t = getTranslations(lang);
const prefix = getUrlPrefix(lang);

const allSeries = await getCollection('series');
const sortedSeries = allSeries.sort((a, b) => a.data.order - b.data.order);

const seriesWithMeta = await Promise.all(
  sortedSeries.map(async (series) => {
    const posts = await getSeriesTimelineIndex(series.id, lang);
    return {
      id: series.id,
      title: series.data.title,
      description: series.data.description || '',
      postCount: posts.length,
      firstPostHero: posts[0]?.heroImage || null,
      firstPostHeroWebp: posts[0]?.heroWebpExists || false,
    };
  })
);

const visibleSeries = seriesWithMeta.filter((s) => s.postCount > 0);
---

<MainLayout
  lang={lang}
  title={t.seriesListingPage.title}
  description={t.seriesListingPage.description}
>
  <section class="py-8 md:py-12">
    <!-- Breadcrumb -->
    <nav class="max-w-4xl mx-auto px-4 mb-6" aria-label="Breadcrumb">
      <ol class="flex items-center gap-2 text-sm text-gray-600 dark:text-gray-300">
        <li>
          <a href={`${prefix}/blog/`} class="hover:text-blue-600 dark:hover:text-blue-400 transition-colors">
            {t.nav.blog}
          </a>
        </li>
        <li aria-hidden="true" class="text-gray-400 dark:text-gray-500">/</li>
        <li aria-current="page" class="font-medium text-gray-900 dark:text-white">
          {t.seriesListingPage.heading}
        </li>
      </ol>
    </nav>

    <!-- Page header -->
    <div class="max-w-4xl mx-auto px-4 mb-10 text-center">
      <h1 class="text-3xl md:text-4xl font-bold text-gray-900 dark:text-white mb-3">
        {t.seriesListingPage.heading}
      </h1>
      <p class="text-lg text-gray-600 dark:text-gray-300 max-w-2xl mx-auto">
        {t.seriesListingPage.description}
      </p>
    </div>

    {visibleSeries.length === 0 ? (
      <div class="text-center py-16">
        <p class="text-gray-600 dark:text-gray-300 text-lg">
          {t.seriesListingPage.emptyState}
        </p>
      </div>
    ) : (
      <div class="max-w-4xl mx-auto px-4 grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
        {visibleSeries.map((series) => (
          <a
            href={`${prefix}/blog/series/${series.id}/`}
            class="group block bg-white dark:bg-gray-800 rounded-xl shadow-sm hover:shadow-lg transition-all duration-300 overflow-hidden border border-gray-100 dark:border-gray-700 hover:border-blue-200 dark:hover:border-blue-700 hover:-translate-y-1"
          >
            {series.firstPostHero ? (
              series.firstPostHeroWebp && series.firstPostHero.match(/\.(png|jpe?g)$/i) ? (
                <picture>
                  <source srcset={series.firstPostHero.replace(/\.(png|jpe?g)$/i, '.webp')} type="image/webp" />
                  <img
                    src={series.firstPostHero}
                    alt=""
                    class="w-full h-40 object-cover"
                    loading="lazy"
                    width="400"
                    height="160"
                  />
                </picture>
              ) : (
                <img
                  src={series.firstPostHero}
                  alt=""
                  class="w-full h-40 object-cover"
                  loading="lazy"
                  width="400"
                  height="160"
                />
              )
            ) : (
              <div class="w-full h-40 bg-gradient-to-br from-blue-50 to-blue-100 dark:from-blue-900/30 dark:to-blue-800/20 flex items-center justify-center">
                <svg class="w-12 h-12 text-blue-300 dark:text-blue-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253" />
                </svg>
              </div>
            )}

            <div class="p-5">
              <h2 class="text-lg font-bold text-gray-900 dark:text-white mb-2 group-hover:text-blue-600 dark:group-hover:text-blue-400 transition-colors">
                {series.title}
              </h2>
              {series.description && (
                <p class="text-sm text-gray-600 dark:text-gray-300 mb-4 line-clamp-2">
                  {series.description}
                </p>
              )}
              <div class="flex items-center justify-between">
                <span class="inline-flex items-center gap-1.5 px-2.5 py-1 rounded-full bg-blue-50 dark:bg-blue-900/30 text-blue-700 dark:text-blue-200 text-xs font-medium">
                  <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253" />
                  </svg>
                  {t.seriesListingPage.postsCount(series.postCount)}
                </span>
                <span class="text-xs font-medium text-blue-600 dark:text-blue-400 group-hover:translate-x-1 transition-transform">
                  {t.seriesListingPage.exploreSeries} &rarr;
                </span>
              </div>
            </div>
          </a>
        ))}
      </div>
    )}

    <!-- Back to blog -->
    <div class="max-w-4xl mx-auto px-4 mt-10">
      <a
        href={`${prefix}/blog/`}
        class="inline-flex items-center gap-2 text-sm text-gray-600 dark:text-gray-300 hover:text-blue-600 dark:hover:text-blue-400 transition-colors"
      >
        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7" />
        </svg>
        {t.seriesPage.backToBlog}
      </a>
    </div>
  </section>
</MainLayout>
