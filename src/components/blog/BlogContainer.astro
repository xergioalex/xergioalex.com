---
import { existsSync } from 'node:fs';
import { resolve } from 'node:path';
import StaticBlogSearch from '@/components/blog/StaticBlogSearch.svelte';
import {
  getPostLanguage,
  getPostSlug,
  groupPostTags,
  isScheduledPost,
} from '@/lib/blog';
import type { BlogPostsResultType } from '@/lib/types';

export interface Props {
  blogPostsResult: BlogPostsResultType;
  currentTag?: string;
  lang?: string;
}
const { blogPostsResult, currentTag, lang = 'en' } = Astro.props;

function checkWebpExists(heroImage: string | undefined): boolean {
  if (!heroImage || !/\.(png|jpe?g)$/i.test(heroImage)) return false;
  const webpPath = heroImage.replace(/\.(png|jpe?g)$/i, '.webp').replace(/^\//, '');
  return existsSync(resolve('public', webpPath));
}

const lightweightPosts = await Promise.all(
  blogPostsResult.postsResult.map(async (post) => {
    const allTags = post.data.tags || [];
    const { primaryTags, topicTags } = await groupPostTags(allTags);
    return {
      id: post.id,
      slug: getPostSlug(post.id),
      lang: getPostLanguage(post.id),
      title: post.data.title,
      description: post.data.description,
      pubDate: post.data.pubDate.toISOString(),
      tags: primaryTags,
      topics: topicTags,
      heroImage: post.data.heroImage,
      heroWebpExists: checkWebpExists(post.data.heroImage),
      seriesCurrent: (post as { seriesCurrent?: number }).seriesCurrent,
      seriesTotal: (post as { seriesTotal?: number }).seriesTotal,
      seriesTitle: (post as { seriesTitle?: string }).seriesTitle,
      isScheduled: isScheduledPost(post),
    };
  })
);
---

<StaticBlogSearch
  postsResult={lightweightPosts}
  currentTag={currentTag}
  totalPages={blogPostsResult.totalPages}
  currentPage={blogPostsResult.currentPage}
  tagsResult={blogPostsResult.tagsResult}
  totalPostsAvailable={blogPostsResult.totalPostsAvailable}
  lang={lang}
  client:idle
/>
