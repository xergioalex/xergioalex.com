---
import FormattedDate from '@/components/FormattedDate.astro';
import type { Language } from '@/lib/i18n';
import { getTranslations } from '@/lib/translations';

interface Props {
  date: Date;
  lang: Language;
}

const { date, lang } = Astro.props;
const t = getTranslations(lang);
---

<span class="inline-flex items-center gap-1 rounded-full bg-gray-100 px-2 py-0.5 text-xs font-medium text-gray-700 dark:bg-gray-800 dark:text-gray-300">
  <svg
    xmlns="http://www.w3.org/2000/svg"
    viewBox="0 0 20 20"
    fill="currentColor"
    class="h-3 w-3 text-blue-600 dark:text-blue-400"
    aria-hidden="true"
  >
    <path fill-rule="evenodd" d="M15.312 11.424a5.5 5.5 0 01-9.201 2.466l-.312-.311h2.433a.75.75 0 000-1.5H3.989a.75.75 0 00-.75.75v4.242a.75.75 0 001.5 0v-2.43l.31.31a7 7 0 0011.712-3.138.75.75 0 00-1.449-.39zm1.23-3.723a.75.75 0 00.219-.53V2.929a.75.75 0 00-1.5 0V5.36l-.31-.31A7 7 0 003.239 8.188a.75.75 0 101.448.389A5.5 5.5 0 0113.89 6.11l.311.31h-2.432a.75.75 0 000 1.5h4.243a.75.75 0 00.53-.219z" clip-rule="evenodd" />
  </svg>
  <span>{t.lastUpdatedOn} <FormattedDate date={date} lang={lang} /></span>
</span>
