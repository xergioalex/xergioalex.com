---
import BlogTopicPage from '@/components/pages/blog/BlogTopicPage.astro';
import { getBlogPosts } from '@/lib/blog';
import type { Language } from '@/lib/i18n';

const lang: Language = 'en';

export async function getStaticPaths() {
  const lang: Language = 'en';

  // Get all topics from all posts
  const allPosts = await getBlogPosts({ lang, pageSize: 9999 });
  const allTopics = Array.from(
    new Set(allPosts.postsResult.flatMap((post) => post.data.topics ?? []))
  );

  const paths = [];
  for (const topic of allTopics) {
    const topicPostsResult = await getBlogPosts({
      lang,
      topic,
    });
    paths.push({
      params: { topic },
      props: { blogPostsResult: topicPostsResult, currentTopic: topic },
    });
  }
  return paths;
}

const { blogPostsResult, currentTopic } = Astro.props;
const { topic } = Astro.params;
---

<BlogTopicPage lang={lang} blogPostsResult={blogPostsResult} currentTopic={currentTopic} topic={topic} />
