---
import InternalLayout from '@/layouts/InternalLayout.astro';

const lifecycle = [
  { status: 'Published', description: 'Live post with pubDate in the past. Appears in listings, search, RSS, and sitemap.', indicator: 'draft: false (or omitted)' },
  { status: 'Scheduled', description: 'Post with a future pubDate. Built but hidden from listings until the date arrives.', indicator: 'pubDate > today' },
  { status: 'Demo', description: 'Test posts in _demo/ folders. Never shown in listings or search. Direct URL access in dev only.', indicator: '_demo/ directory' },
];

const frontmatterFields = [
  { field: 'title', type: 'string', required: true, description: 'Post title (translated per language)' },
  { field: 'description', type: 'string', required: true, description: 'Meta description, 130-160 characters' },
  { field: 'pubDate', type: 'date', required: true, description: 'Publication date (ISO format)' },
  { field: 'updatedDate', type: 'date', required: false, description: 'Last significant update' },
  { field: 'heroImage', type: 'string', required: false, description: 'Path: /images/blog/posts/{slug}/hero.{ext}' },
  { field: 'heroLayout', type: 'enum', required: false, description: 'banner | side-by-side | minimal | none' },
  { field: 'tags', type: 'string[]', required: true, description: 'Tag slugs, max 5 (1-2 primary + 1-3 secondary)' },
  { field: 'keywords', type: 'string[]', required: false, description: 'SEO keywords, 5-8 per language' },
  { field: 'series', type: 'string', required: false, description: 'Series slug (English only)' },
  { field: 'seriesOrder', type: 'number', required: false, description: 'Position in series (1-based)' },
  { field: 'draft', type: 'boolean', required: false, description: 'Exclude from production if true' },
];

const heroLayouts = [
  { layout: 'banner', aspect: 'Landscape', description: 'Full-width banner image above the title. Default layout for most posts.', usage: 'Wide/panoramic hero images' },
  { layout: 'side-by-side', aspect: 'Square', description: 'Image on one side, title and meta on the other. Good for portrait or square art.', usage: 'Square or portrait hero images' },
  { layout: 'minimal', aspect: 'Thumbnail', description: 'Small thumbnail beside the title. Minimal visual footprint.', usage: 'When image is secondary to content' },
  { layout: 'none', aspect: 'N/A', description: 'No hero image displayed. Text-only header.', usage: 'Text-focused posts, no image needed' },
];

const primaryTags = [
  { slug: 'tech', description: 'Technology and software engineering' },
  { slug: 'personal', description: 'Personal reflections and life experiences' },
  { slug: 'talks', description: 'Conference talks and presentations' },
  { slug: 'trading', description: 'Trading and financial markets' },
  { slug: 'portfolio', description: 'Portfolio projects and case studies' },
  { slug: 'dailybot', description: 'DailyBot product and company' },
];

const secondaryTags = [
  { slug: 'web-development', description: 'Web development topics' },
  { slug: 'javascript', description: 'JavaScript and TypeScript' },
  { slug: 'ai', description: 'Artificial intelligence and ML' },
  { slug: 'blockchain', description: 'Blockchain and crypto' },
  { slug: 'devops', description: 'DevOps and infrastructure' },
  { slug: 'python', description: 'Python programming' },
  { slug: 'university', description: 'Academic and university projects' },
  { slug: 'database', description: 'Database systems' },
  { slug: 'iot', description: 'Internet of Things' },
  { slug: 'design', description: 'Design and UX' },
];

const commands = [
  { command: 'npm run images:optimize', description: 'Process staged images in _staging/ to WebP' },
  { command: 'npm run build', description: 'Full production build (includes image processing)' },
  { command: 'npm run dev', description: 'Dev server with hot reload at localhost:4444' },
  { command: 'npm run md:check', description: 'Verify every HTML page has a matching .md for agents' },
];

const writingRules = [
  { rule: 'Personal voice', description: 'First person, conversational tone. Author shares real experiences and opinions.' },
  { rule: 'Tuteo for Spanish', description: 'Use "tú" form (tuteo), never "vos" (voseo). Colombian Spanish phrasing.' },
  { rule: 'No placeholders', description: 'Zero tolerance for [AUTHOR: ...], [TODO: ...], [TBD], or any bracketed fill-in-later text.' },
  { rule: 'Keywords', description: '5-8 SEO keywords per post, per language. Placed in frontmatter keywords array.' },
  { rule: 'Diacritical marks', description: 'Spanish content MUST have proper ñ, á, é, í, ó, ú. Validate before committing.' },
  { rule: 'English slugs only', description: 'All filenames, series slugs, and image directories use English slugs, even for Spanish content.' },
];
---

<InternalLayout title="Blog System" description="Blog authoring workflow and conventions" section="guide" subsection="blog">

  <!-- Post Lifecycle -->
  <section class="mb-12">
    <h2 class="text-xl md:text-2xl font-bold mb-4">Post Lifecycle</h2>
    <div class="grid grid-cols-1 sm:grid-cols-3 gap-4">
      {lifecycle.map((l) => (
        <div class="rounded-xl border border-gray-200 dark:border-gray-700 p-4">
          <div class="flex items-baseline justify-between mb-2">
            <h3 class="font-semibold">{l.status}</h3>
            <span class="text-xs px-2 py-0.5 rounded-full bg-secondary/10 text-secondary font-medium">{l.indicator}</span>
          </div>
          <p class="text-sm text-gray-600 dark:text-gray-300">{l.description}</p>
        </div>
      ))}
    </div>
  </section>

  <!-- Frontmatter Quick Reference -->
  <section class="mb-12">
    <h2 class="text-xl md:text-2xl font-bold mb-4">Frontmatter Quick Reference</h2>
    <div class="rounded-2xl border border-gray-200 dark:border-gray-700 overflow-hidden">
      <div class="overflow-x-auto">
        <table class="w-full text-sm">
          <thead>
            <tr class="border-b border-gray-200 dark:border-gray-700 bg-gray-50 dark:bg-gray-800">
              <th class="text-left py-3 px-4 font-semibold">Field</th>
              <th class="text-left py-3 px-4 font-semibold">Type</th>
              <th class="text-left py-3 px-4 font-semibold">Required</th>
              <th class="text-left py-3 px-4 font-semibold">Description</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-gray-100 dark:divide-gray-800">
            {frontmatterFields.map((f) => (
              <tr>
                <td class="py-3 px-4"><code class="text-xs font-medium">{f.field}</code></td>
                <td class="py-3 px-4"><code class="text-xs">{f.type}</code></td>
                <td class="py-3 px-4 text-gray-600 dark:text-gray-300">{f.required ? 'Yes' : 'No'}</td>
                <td class="py-3 px-4 text-gray-600 dark:text-gray-300">{f.description}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </div>
  </section>

  <!-- Hero Layouts -->
  <section class="mb-12">
    <h2 class="text-xl md:text-2xl font-bold mb-4">Hero Layouts</h2>
    <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
      {heroLayouts.map((h) => (
        <div class="rounded-xl border border-gray-200 dark:border-gray-700 p-4">
          <div class="flex items-baseline justify-between mb-2">
            <h3 class="font-semibold">{h.layout}</h3>
            <span class="text-xs px-2 py-0.5 rounded-full bg-secondary/10 text-secondary font-medium">{h.aspect}</span>
          </div>
          <p class="text-sm text-gray-600 dark:text-gray-300 mb-1">{h.description}</p>
          <p class="text-xs text-gray-600 dark:text-gray-300"><strong>Use for:</strong> {h.usage}</p>
        </div>
      ))}
    </div>
  </section>

  <!-- Tags -->
  <section class="mb-12">
    <h2 class="text-xl md:text-2xl font-bold mb-4">Tags</h2>
    <h3 class="font-semibold mb-3">Primary Tags</h3>
    <div class="rounded-2xl border border-gray-200 dark:border-gray-700 overflow-hidden mb-6">
      <div class="overflow-x-auto">
        <table class="w-full text-sm">
          <thead>
            <tr class="border-b border-gray-200 dark:border-gray-700 bg-gray-50 dark:bg-gray-800">
              <th class="text-left py-3 px-4 font-semibold">Slug</th>
              <th class="text-left py-3 px-4 font-semibold">Description</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-gray-100 dark:divide-gray-800">
            {primaryTags.map((t) => (
              <tr>
                <td class="py-3 px-4"><code class="text-xs font-medium">{t.slug}</code></td>
                <td class="py-3 px-4 text-gray-600 dark:text-gray-300">{t.description}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </div>
    <h3 class="font-semibold mb-3">Secondary Tags</h3>
    <div class="rounded-2xl border border-gray-200 dark:border-gray-700 overflow-hidden">
      <div class="overflow-x-auto">
        <table class="w-full text-sm">
          <thead>
            <tr class="border-b border-gray-200 dark:border-gray-700 bg-gray-50 dark:bg-gray-800">
              <th class="text-left py-3 px-4 font-semibold">Slug</th>
              <th class="text-left py-3 px-4 font-semibold">Description</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-gray-100 dark:divide-gray-800">
            {secondaryTags.map((t) => (
              <tr>
                <td class="py-3 px-4"><code class="text-xs font-medium">{t.slug}</code></td>
                <td class="py-3 px-4 text-gray-600 dark:text-gray-300">{t.description}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </div>
  </section>

  <!-- Series -->
  <section class="mb-12">
    <h2 class="text-xl md:text-2xl font-bold mb-4">Series</h2>
    <div class="space-y-4">
      <div class="rounded-xl border border-gray-200 dark:border-gray-700 p-4">
        <h3 class="font-semibold mb-1">Adding a Post to a Series</h3>
        <p class="text-sm text-gray-600 dark:text-gray-300 mb-2">
          Add <code class="text-xs">series: "series-slug"</code> and <code class="text-xs">seriesOrder: N</code> to the post's frontmatter. The series navigation renders automatically below the post content.
        </p>
        <div class="rounded-lg bg-gray-50 dark:bg-gray-800 p-2">
          <code class="text-xs">series: "the-library-of-tomorrow"<br/>seriesOrder: 3</code>
        </div>
      </div>
      <div class="rounded-xl border border-gray-200 dark:border-gray-700 p-4">
        <h3 class="font-semibold mb-1">Series Definition</h3>
        <p class="text-sm text-gray-600 dark:text-gray-300 mb-2">
          Series are defined in <code class="text-xs">src/content/series/</code>. Slugs MUST be in English, even for Spanish content.
        </p>
        <div class="rounded-lg bg-gray-50 dark:bg-gray-800 p-2">
          <code class="text-xs">src/content/series/the-library-of-tomorrow.md</code>
        </div>
      </div>
    </div>
  </section>

  <!-- Images -->
  <section class="mb-12">
    <h2 class="text-xl md:text-2xl font-bold mb-4">Images</h2>
    <div class="space-y-4">
      <div class="rounded-xl border border-gray-200 dark:border-gray-700 p-4">
        <h3 class="font-semibold mb-1">Path Convention</h3>
        <p class="text-sm text-gray-600 dark:text-gray-300 mb-2">
          Blog images live in <code class="text-xs">public/images/blog/posts/{'{slug}'}/ </code>. Hero images are named <code class="text-xs">hero.{'{ext}'}</code>.
        </p>
        <div class="rounded-lg bg-gray-50 dark:bg-gray-800 p-2">
          <code class="text-xs">public/images/blog/posts/my-first-post/hero.webp</code>
        </div>
      </div>
      <div class="rounded-xl border border-gray-200 dark:border-gray-700 p-4">
        <h3 class="font-semibold mb-1">Staging Workflow</h3>
        <p class="text-sm text-gray-600 dark:text-gray-300 mb-2">
          Drop raw images in <code class="text-xs">public/images/blog/_staging/</code>, then run <code class="text-xs">npm run images:optimize</code> to resize and convert to WebP.
        </p>
      </div>
    </div>
  </section>

  <!-- Commands -->
  <section class="mb-12">
    <h2 class="text-xl md:text-2xl font-bold mb-4">Commands</h2>
    <div class="rounded-2xl border border-gray-200 dark:border-gray-700 overflow-hidden">
      <div class="overflow-x-auto">
        <table class="w-full text-sm">
          <thead>
            <tr class="border-b border-gray-200 dark:border-gray-700 bg-gray-50 dark:bg-gray-800">
              <th class="text-left py-3 px-4 font-semibold">Command</th>
              <th class="text-left py-3 px-4 font-semibold">Description</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-gray-100 dark:divide-gray-800">
            {commands.map((c) => (
              <tr>
                <td class="py-3 px-4"><code class="text-xs font-medium">{c.command}</code></td>
                <td class="py-3 px-4 text-gray-600 dark:text-gray-300">{c.description}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </div>
  </section>

  <!-- Writing Rules -->
  <section class="mb-12">
    <h2 class="text-xl md:text-2xl font-bold mb-4">Writing Rules</h2>
    <div class="space-y-4">
      {writingRules.map((r) => (
        <div class="rounded-xl border border-gray-200 dark:border-gray-700 p-4">
          <h3 class="font-semibold mb-1">{r.rule}</h3>
          <p class="text-sm text-gray-600 dark:text-gray-300">{r.description}</p>
        </div>
      ))}
    </div>
  </section>

</InternalLayout>
