---
import ShowcaseLayout from '@/layouts/ShowcaseLayout.astro';

const breadcrumbExamples = [
  {
    name: 'Blog Post',
    description: 'Used on individual blog post pages (BlogPostPage.astro)',
    items: [
      { label: 'Home', href: '#', isLink: true },
      { label: 'Blog', href: '#', isLink: true },
      { label: 'Why I Ditched ESLint for Biome', href: null, isLink: false },
    ],
  },
  {
    name: 'Series Listing',
    description:
      'Used on the series listing page (BlogSeriesListingPage.astro)',
    items: [
      { label: 'Blog', href: '#', isLink: true },
      { label: 'Series', href: null, isLink: false },
    ],
  },
  {
    name: 'Series Detail',
    description: 'Used on individual series pages (BlogSeriesPage.astro)',
    items: [
      { label: 'Blog', href: '#', isLink: true },
      { label: 'Series', href: '#', isLink: true },
      { label: 'Building XergioAleX.com', href: null, isLink: false },
    ],
  },
];
---

<ShowcaseLayout title="Navigation" description="Breadcrumbs, navigation links, and wayfinding patterns" section="navigation">

  <!-- Breadcrumbs -->
  <section class="mb-12" data-component="breadcrumbs">
    <h2 class="text-xl md:text-2xl font-bold mb-2">Breadcrumbs</h2>
    <p class="text-sm text-gray-600 dark:text-gray-300 mb-6">
      Standard breadcrumb pattern used across all content pages. Uses a flat <code class="text-xs bg-gray-100 dark:bg-gray-800 px-1 py-0.5 rounded">&lt;nav&gt;</code> with flexbox layout (not <code class="text-xs bg-gray-100 dark:bg-gray-800 px-1 py-0.5 rounded">&lt;ol&gt;/&lt;li&gt;</code>).
    </p>

    <!-- Live examples -->
    <div class="space-y-6">
      {breadcrumbExamples.map((example) => (
        <div class="rounded-lg border border-gray-200 dark:border-gray-700 p-4">
          <div class="text-xs font-medium text-gray-600 dark:text-gray-300 mb-3 uppercase tracking-wider">{example.name}</div>
          <nav class="flex flex-wrap items-center gap-x-2 text-sm" aria-label="Breadcrumb">
            {example.items.map((item, i) => (
              <>
                {i > 0 && (
                  <span class="font-semibold text-gray-600 dark:text-gray-300 select-none" aria-hidden="true">/</span>
                )}
                {item.isLink ? (
                  <a href={item.href} class="font-semibold text-gray-600 transition-colors hover:text-blue-600 dark:text-gray-300 dark:hover:text-blue-400">{item.label}</a>
                ) : (
                  <span class="truncate font-normal text-gray-600 dark:text-gray-300" aria-current="page">{item.label}</span>
                )}
              </>
            ))}
          </nav>
          <div class="text-xs text-gray-600 dark:text-gray-300 mt-2">{example.description}</div>
        </div>
      ))}
    </div>
  </section>

  <!-- Anatomy -->
  <section class="mb-12" data-component="breadcrumb-anatomy">
    <h2 class="text-xl md:text-2xl font-bold mb-4">Anatomy & Rules</h2>
    <div class="space-y-3 text-sm text-gray-600 dark:text-gray-300">
      <div class="flex gap-3">
        <span class="font-semibold text-gray-900 dark:text-white shrink-0">Container:</span>
        <span><code class="text-xs bg-gray-100 dark:bg-gray-800 px-1 py-0.5 rounded">&lt;nav&gt;</code> with <code class="text-xs bg-gray-100 dark:bg-gray-800 px-1 py-0.5 rounded">aria-label="Breadcrumb"</code> and <code class="text-xs bg-gray-100 dark:bg-gray-800 px-1 py-0.5 rounded">flex flex-wrap items-center gap-x-2 text-sm</code></span>
      </div>
      <div class="flex gap-3">
        <span class="font-semibold text-gray-900 dark:text-white shrink-0">Links:</span>
        <span><code class="text-xs bg-gray-100 dark:bg-gray-800 px-1 py-0.5 rounded">&lt;a&gt;</code> with <code class="text-xs bg-gray-100 dark:bg-gray-800 px-1 py-0.5 rounded">font-semibold text-gray-600 transition-colors hover:text-blue-600 dark:text-gray-300 dark:hover:text-blue-400</code></span>
      </div>
      <div class="flex gap-3">
        <span class="font-semibold text-gray-900 dark:text-white shrink-0">Separator:</span>
        <span><code class="text-xs bg-gray-100 dark:bg-gray-800 px-1 py-0.5 rounded">&lt;span&gt;</code> with <code class="text-xs bg-gray-100 dark:bg-gray-800 px-1 py-0.5 rounded">font-semibold text-gray-600 dark:text-gray-300 select-none</code> and <code class="text-xs bg-gray-100 dark:bg-gray-800 px-1 py-0.5 rounded">aria-hidden="true"</code>. Character: <code class="text-xs bg-gray-100 dark:bg-gray-800 px-1 py-0.5 rounded">/</code></span>
      </div>
      <div class="flex gap-3">
        <span class="font-semibold text-gray-900 dark:text-white shrink-0">Current page:</span>
        <span><code class="text-xs bg-gray-100 dark:bg-gray-800 px-1 py-0.5 rounded">&lt;span&gt;</code> with <code class="text-xs bg-gray-100 dark:bg-gray-800 px-1 py-0.5 rounded">truncate font-normal text-gray-600 dark:text-gray-300</code> and <code class="text-xs bg-gray-100 dark:bg-gray-800 px-1 py-0.5 rounded">aria-current="page"</code></span>
      </div>
    </div>
  </section>

  <!-- Code Example -->
  <section class="mb-12">
    <details class="rounded-lg border border-gray-200 dark:border-gray-700" open>
      <summary class="px-4 py-3 cursor-pointer text-sm font-medium hover:bg-gray-50 dark:hover:bg-gray-800">
        Show code
      </summary>
      <pre class="p-4 text-xs overflow-x-auto bg-gray-50 dark:bg-gray-800"><code>&lt;nav
  class="mb-6 flex flex-wrap items-center gap-x-2 text-sm"
  aria-label="Breadcrumb"
&gt;
  &lt;a
    href=&#123;homeUrl&#125;
    class="font-semibold text-gray-600 transition-colors
           hover:text-blue-600
           dark:text-gray-300 dark:hover:text-blue-400"
  &gt;
    Home
  &lt;/a&gt;
  &lt;span
    class="font-semibold text-gray-600 dark:text-gray-300 select-none"
    aria-hidden="true"
  &gt;
    /
  &lt;/span&gt;
  &lt;a
    href=&#123;blogUrl&#125;
    class="font-semibold text-gray-600 transition-colors
           hover:text-blue-600
           dark:text-gray-300 dark:hover:text-blue-400"
  &gt;
    Blog
  &lt;/a&gt;
  &lt;span
    class="font-semibold text-gray-600 dark:text-gray-300 select-none"
    aria-hidden="true"
  &gt;
    /
  &lt;/span&gt;
  &lt;span
    class="truncate font-normal text-gray-600 dark:text-gray-300"
    aria-current="page"
  &gt;
    &#123;title&#125;
  &lt;/span&gt;
&lt;/nav&gt;</code></pre>
    </details>
  </section>

  <!-- Do / Don't -->
  <section class="mb-12" data-component="breadcrumb-guidelines">
    <h2 class="text-xl md:text-2xl font-bold mb-4">Guidelines</h2>
    <div class="grid gap-4 sm:grid-cols-2">
      <div class="rounded-lg border-2 border-green-200 dark:border-green-800 p-4">
        <div class="text-sm font-bold text-green-700 dark:text-green-300 mb-2">DO</div>
        <ul class="text-sm text-gray-600 dark:text-gray-300 space-y-1">
          <li>Use flat <code class="text-xs bg-gray-100 dark:bg-gray-800 px-1 py-0.5 rounded">&lt;nav&gt;</code> + <code class="text-xs bg-gray-100 dark:bg-gray-800 px-1 py-0.5 rounded">&lt;a&gt;</code>/<code class="text-xs bg-gray-100 dark:bg-gray-800 px-1 py-0.5 rounded">&lt;span&gt;</code> (no list markup)</li>
          <li>Include <code class="text-xs bg-gray-100 dark:bg-gray-800 px-1 py-0.5 rounded">aria-label="Breadcrumb"</code> on the nav</li>
          <li>Mark current page with <code class="text-xs bg-gray-100 dark:bg-gray-800 px-1 py-0.5 rounded">aria-current="page"</code></li>
          <li>Hide separators with <code class="text-xs bg-gray-100 dark:bg-gray-800 px-1 py-0.5 rounded">aria-hidden="true"</code> + <code class="text-xs bg-gray-100 dark:bg-gray-800 px-1 py-0.5 rounded">select-none</code></li>
          <li>Use <code class="text-xs bg-gray-100 dark:bg-gray-800 px-1 py-0.5 rounded">truncate</code> on the current page label</li>
          <li>Use <code class="text-xs bg-gray-100 dark:bg-gray-800 px-1 py-0.5 rounded">font-semibold</code> for links, <code class="text-xs bg-gray-100 dark:bg-gray-800 px-1 py-0.5 rounded">font-normal</code> for current page</li>
        </ul>
      </div>
      <div class="rounded-lg border-2 border-red-200 dark:border-red-800 p-4">
        <div class="text-sm font-bold text-red-700 dark:text-red-300 mb-2">DON'T</div>
        <ul class="text-sm text-gray-600 dark:text-gray-300 space-y-1">
          <li>Use <code class="text-xs bg-gray-100 dark:bg-gray-800 px-1 py-0.5 rounded">&lt;ol&gt;</code>/<code class="text-xs bg-gray-100 dark:bg-gray-800 px-1 py-0.5 rounded">&lt;li&gt;</code> list markup</li>
          <li>Use <code class="text-xs bg-gray-100 dark:bg-gray-800 px-1 py-0.5 rounded">text-gray-400</code> or <code class="text-xs bg-gray-100 dark:bg-gray-800 px-1 py-0.5 rounded">dark:text-gray-500</code> for separators (fails WCAG)</li>
          <li>Make the current page a link</li>
          <li>Use <code class="text-xs bg-gray-100 dark:bg-gray-800 px-1 py-0.5 rounded">font-medium text-gray-900</code> for the current page (too heavy)</li>
          <li>Omit accessibility attributes</li>
        </ul>
      </div>
    </div>
  </section>

  <!-- Agent Reference -->
  <section class="mt-16 border-t border-gray-200 dark:border-gray-700 pt-8" data-agent-reference="true">
    <h2 class="text-lg font-bold mb-4">Agent Reference</h2>
    <div class="overflow-x-auto">
      <table class="w-full text-sm border-collapse">
        <thead>
          <tr class="border-b border-gray-200 dark:border-gray-700 text-left">
            <th class="py-2 pr-4 font-semibold">Element</th>
            <th class="py-2 pr-4 font-semibold">Tag</th>
            <th class="py-2 font-semibold">Classes</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-gray-100 dark:divide-gray-800">
          <tr>
            <td class="py-2 pr-4 font-medium">Container</td>
            <td class="py-2 pr-4"><code class="text-xs">nav</code></td>
            <td class="py-2"><code class="text-xs">mb-6 flex flex-wrap items-center gap-x-2 text-sm</code></td>
          </tr>
          <tr>
            <td class="py-2 pr-4 font-medium">Link</td>
            <td class="py-2 pr-4"><code class="text-xs">a</code></td>
            <td class="py-2"><code class="text-xs">font-semibold text-gray-600 transition-colors hover:text-blue-600 dark:text-gray-300 dark:hover:text-blue-400</code></td>
          </tr>
          <tr>
            <td class="py-2 pr-4 font-medium">Separator</td>
            <td class="py-2 pr-4"><code class="text-xs">span</code></td>
            <td class="py-2"><code class="text-xs">font-semibold text-gray-600 dark:text-gray-300 select-none</code></td>
          </tr>
          <tr>
            <td class="py-2 pr-4 font-medium">Current page</td>
            <td class="py-2 pr-4"><code class="text-xs">span</code></td>
            <td class="py-2"><code class="text-xs">truncate font-normal text-gray-600 dark:text-gray-300</code></td>
          </tr>
        </tbody>
      </table>
    </div>
  </section>
</ShowcaseLayout>
