---
import { getCollection } from 'astro:content';
import BlogPostPage from '@/components/pages/blog/BlogPostPage.astro';
import {
  getPostSlug,
  isDemoPost,
  isDraftPost,
  isScheduledPost,
  shouldHideDrafts,
} from '@/lib/blog';

export async function getStaticPaths() {
  const allPosts = await getCollection('blog');
  const posts = allPosts.filter((post) => {
    if (!post.id.startsWith('es/')) return false;
    // Demo posts are only available in dev mode, not in any build
    if (isDemoPost(post)) return import.meta.env.DEV;
    // Scheduled posts (future pubDate) are only available in dev mode
    if (isScheduledPost(post)) return import.meta.env.DEV;
    // Drafts are shown on dev + preview branches, hidden on production
    if (isDraftPost(post) && shouldHideDrafts()) return false;
    return true;
  });
  return posts.map((post) => ({
    params: { slug: getPostSlug(post.id) },
    props: { post },
  }));
}

const { post } = Astro.props;
---

<BlogPostPage lang="es" post={post} />
