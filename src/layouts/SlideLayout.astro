---
import '@/styles/global.css';
import 'reveal.js/reveal.css';
import 'reveal.js/theme/black.css';
import 'reveal.js/theme/white.css';

import BaseHead from '@/components/BaseHead.astro';
import { SITE_TITLE } from '@/lib/constances';
import { getUrlPrefix, type Language } from '@/lib/i18n';
import { getTranslations } from '@/lib/translations';

interface Props {
  lang: Language;
  title: string;
  description: string;
  image?: string;
  showRevealChrome?: boolean;
  deckSlug: string;
  isDraft?: boolean;
}

const {
  lang,
  title,
  description,
  image,
  showRevealChrome = true,
  deckSlug,
  isDraft = false,
} = Astro.props;

const t = getTranslations(lang);
const prefix = getUrlPrefix(lang);
const catalogUrl = `${prefix}/slides`;
const alternateLang = lang === 'en' ? 'es' : 'en';
const alternatePrefix = getUrlPrefix(alternateLang);
const alternateUrl = `${alternatePrefix}/slides/${deckSlug}`;
const langSwitchLabel = lang === 'en' ? 'Ver en español' : 'View in English';
---

<html lang={lang}>
  <head>
    <BaseHead
      title={`${title} | ${SITE_TITLE}`}
      description={description}
      image={image}
      lang={lang}
      ogType="article"
    />
    <style is:global>
      body.reveal-theme-dark {
        background: #111;
      }
      body.reveal-theme-light {
        background: #fff;
      }
      body.reveal-theme-light .reveal {
        color: #222;
      }
      /* Fix: Reveal v6 black theme uses dark text (#191919) which is unreadable
         on slides with dark backgrounds. Force white text on those slides. */
      .reveal .slides section.has-dark-background,
      .reveal .slides section.has-dark-background h1,
      .reveal .slides section.has-dark-background h2,
      .reveal .slides section.has-dark-background h3,
      .reveal .slides section.has-dark-background h4,
      .reveal .slides section.has-dark-background p,
      .reveal .slides section.has-dark-background li,
      .reveal .slides section.has-dark-background small,
      .reveal .slides section[data-background-gradient] h1,
      .reveal .slides section[data-background-gradient] h2,
      .reveal .slides section[data-background-gradient] h3,
      .reveal .slides section[data-background-gradient] p,
      .reveal .slides section[data-background-gradient] small {
        color: #fff !important;
      }
      body.reveal-theme-dark .reveal .controls {
        color: #42affa;
      }
      body.reveal-theme-light .reveal .controls {
        color: #2a76dd;
      }
      body.reveal-theme-light .reveal .progress {
        color: #2a76dd;
      }
      .slide-chrome {
        position: fixed;
        z-index: 50;
        padding: 0.75rem 1rem;
        font-size: 0.8125rem;
        font-family: system-ui, sans-serif;
      }
      .slide-chrome a {
        text-decoration: none;
        opacity: 0.7;
        transition: opacity 0.2s;
      }
      .slide-chrome a:hover,
      .slide-chrome a:focus-visible {
        opacity: 1;
      }
      body.reveal-theme-dark .slide-chrome a {
        color: #d1d5db;
      }
      body.reveal-theme-light .slide-chrome a {
        color: #4b5563;
      }
      .slide-chrome a:focus-visible {
        outline: 2px solid currentColor;
        outline-offset: 2px;
        border-radius: 4px;
      }
    </style>
    <slot name="head" />
  </head>
  <body class="reveal-theme-dark m-0 p-0 overflow-hidden">
    <nav class="slide-chrome top-0 left-0" aria-label="Deck navigation">
      <a href={catalogUrl} aria-label={`${t.slides.exitToCatalog} — ${SITE_TITLE}`}>
        ← {SITE_TITLE.split(' - ')[0]}
      </a>
    </nav>

    <nav class="slide-chrome top-0 right-0 flex items-center gap-3" aria-label="Language switcher">
      {isDraft && (
        <span
          class="inline-flex items-center rounded-full bg-purple-600 px-2 py-0.5 text-[11px] font-bold uppercase tracking-wide text-white shadow-sm"
          title={t.draftBadge}
        >
          {t.draftBadge}
        </span>
      )}
      <a href={alternateUrl} hreflang={alternateLang}>
        {langSwitchLabel}
      </a>
    </nav>

    {showRevealChrome && (
      <div class="slide-chrome bottom-0 right-0">
        <a href="?print-pdf" target="_blank" rel="noopener noreferrer" aria-label={t.slides.printPdf}>
          {t.slides.printPdf}
        </a>
      </div>
    )}

    <div class="reveal" id="reveal-deck">
      <slot />
    </div>

    <script is:inline>
      (function() {
        var html = document.documentElement;
        var body = document.body;

        function syncTheme() {
          var isDark = html.classList.contains('dark');
          body.classList.remove('reveal-theme-dark', 'reveal-theme-light');
          body.classList.add(isDark ? 'reveal-theme-dark' : 'reveal-theme-light');
        }

        syncTheme();

        var observer = new MutationObserver(function(mutations) {
          for (var i = 0; i < mutations.length; i++) {
            if (mutations[i].attributeName === 'class') {
              syncTheme();
              break;
            }
          }
        });
        observer.observe(html, { attributes: true, attributeFilter: ['class'] });

        window.addEventListener('reveal:ready', function() {
          var deck = document.getElementById('reveal-deck');
          if (deck) {
            deck.classList.remove('opacity-0');
          }
        });
      })();
    </script>
  </body>
</html>
