---
import 'reveal.js/reveal.css';

import { SITE_TITLE } from '@/lib/constances';
import { getUrlPrefix, type Language } from '@/lib/i18n';
import { getTranslations } from '@/lib/translations';

interface Props {
  lang: Language;
  title: string;
  description: string;
  image?: string;
  showRevealChrome?: boolean;
  deckSlug: string;
  isDraft?: boolean;
}

const {
  lang,
  title,
  description,
  image = '/images/og-default.png',
  showRevealChrome = true,
  deckSlug,
  isDraft = false,
} = Astro.props;

const t = getTranslations(lang);
const prefix = getUrlPrefix(lang);
const catalogUrl = `${prefix}/slides`;
const alternateLang = lang === 'en' ? 'es' : 'en';
const alternatePrefix = getUrlPrefix(alternateLang);
const alternateUrl = `${alternatePrefix}/slides/${deckSlug}`;
const langSwitchLabel = lang === 'en' ? 'Ver en español' : 'View in English';
const fullTitle = `${title} | ${SITE_TITLE}`;
const canonicalURL = new URL(Astro.url.pathname, Astro.site);
const absoluteImageUrl = new URL(image, Astro.site ?? Astro.url).href;
---

<html lang={lang}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width,initial-scale=1" />
    <link rel="icon" href="/favicon.ico" sizes="32x32" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="canonical" href={canonicalURL} />
    <title>{fullTitle}</title>
    <meta name="description" content={description} />
    <meta property="og:type" content="article" />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={absoluteImageUrl} />
    <meta property="og:url" content={canonicalURL.href} />
    <meta property="twitter:card" content="summary_large_image" />
    <meta property="twitter:title" content={fullTitle} />
    <meta property="twitter:description" content={description} />
    <meta property="twitter:image" content={absoluteImageUrl} />
    <style is:global>
      .reveal {
        font-family: 'Source Sans Pro', Helvetica, sans-serif;
        font-size: 42px;
      }
      .reveal .slides section h1,
      .reveal .slides section h2,
      .reveal .slides section h3,
      .reveal .slides section h4 {
        text-transform: uppercase;
        font-weight: 700;
        letter-spacing: 0.02em;
      }
      .reveal .slides section h1 { font-size: 2.5em; }
      .reveal .slides section h2 { font-size: 1.6em; }
      .reveal .slides section h3 { font-size: 1.15em; }
      .reveal .slides section a { color: #42affa; }
      .reveal .slides section code { font-family: monospace; }
      .reveal .controls { color: #42affa; }
      .reveal .progress span { background: #42affa; }

      /* Slide content always uses light text on dark backgrounds */
      .reveal .slides section,
      .reveal .slides section p,
      .reveal .slides section li,
      .reveal .slides section small,
      .reveal .slides section code,
      .reveal .slides section pre { color: #eee; }
      .reveal .slides section h1,
      .reveal .slides section h2,
      .reveal .slides section h3,
      .reveal .slides section h4 { color: #fff; }

      /* Chrome adapts to site theme */
      body[data-slide-theme="dark"] .slide-chrome a { color: #d1d5db; }
      body[data-slide-theme="light"] .slide-chrome a { color: #4b5563; }
      .slide-chrome {
        position: fixed;
        z-index: 50;
        padding: 0.75rem 1rem;
        font-size: 0.8125rem;
        font-family: system-ui, sans-serif;
      }
      .slide-chrome a {
        text-decoration: none;
        opacity: 0.7;
        transition: opacity 0.2s;
        color: #d1d5db;
      }
      .slide-chrome a:hover,
      .slide-chrome a:focus-visible {
        opacity: 1;
      }
      .slide-chrome a:focus-visible {
        outline: 2px solid currentColor;
        outline-offset: 2px;
        border-radius: 4px;
      }
      .slide-chrome .draft-badge {
        display: inline-flex;
        align-items: center;
        border-radius: 9999px;
        background: #9333ea;
        padding: 2px 8px;
        font-size: 11px;
        font-weight: bold;
        text-transform: uppercase;
        letter-spacing: 0.05em;
        color: #fff;
      }
    </style>
    <slot name="head" />
  </head>
  <body data-slide-theme="dark" style="margin:0; padding:0; overflow:hidden; background:#111; color:#eee;">
    <nav class="slide-chrome" style="top:0; left:0;" aria-label="Deck navigation">
      <a href={catalogUrl} aria-label={`${t.slides.exitToCatalog} — ${SITE_TITLE}`}>
        ← {SITE_TITLE.split(' - ')[0]}
      </a>
    </nav>

    <nav class="slide-chrome" style="top:0; right:0; display:flex; align-items:center; gap:12px;" aria-label="Language switcher">
      {isDraft && (
        <span class="draft-badge" title={t.draftBadge}>
          {t.draftBadge}
        </span>
      )}
      <a href={alternateUrl} hreflang={alternateLang}>
        {langSwitchLabel}
      </a>
    </nav>

    {showRevealChrome && (
      <div class="slide-chrome" style="bottom:0; right:0;">
        <a href="?print-pdf" target="_blank" rel="noopener noreferrer" aria-label={t.slides.printPdf}>
          {t.slides.printPdf}
        </a>
      </div>
    )}

    <div class="reveal" id="reveal-deck">
      <slot />
    </div>

    <script is:inline>
      (function() {
        var html = document.documentElement;
        var body = document.body;
        function syncTheme() {
          var isDark = html.classList.contains('dark');
          body.setAttribute('data-slide-theme', isDark ? 'dark' : 'light');
          body.style.background = isDark ? '#111' : '#f8f8f8';
          body.style.color = isDark ? '#eee' : '#222';
        }
        syncTheme();
        new MutationObserver(function(m) {
          for (var i = 0; i < m.length; i++) {
            if (m[i].attributeName === 'class') { syncTheme(); break; }
          }
        }).observe(html, { attributes: true, attributeFilter: ['class'] });
      })();
    </script>
  </body>
</html>
