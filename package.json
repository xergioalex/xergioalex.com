  "homepage": "https://xergioalex.com",
  "repository": {
    "type": "git",
    "url": "https://github.com/xergioalex/xergioalex.com"
  },
  "type": "module",
  "version": "0.0.83",
  "scripts": {
    "dev": "astro dev",
    "build": "astro check && astro build",
    "prebuild": "echo 'All images are natively WebP — no pre-processing needed'",
    "astro": "astro",
    "astro:check": "astro check",
    "astro:preview": "astro preview",
    "biome:check": "biome check",
    "biome:fix": "biome check --write",
    "biome:fix:unsafe": "biome check --write --unsafe",
    "ncu:check": "ncu",
    "ncu:upgrade": "ncu -u",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "images:optimize": "node scripts/optimize-images.mjs",
    "images:webp": "echo 'All images are natively WebP — no generation needed'",
    "search:budgets": "node scripts/check-search-performance-budgets.mjs",
    "lighthouse": "lhci autorun",
    "lighthouse:full": "lhci autorun --config=lighthouserc.full.cjs",
    "release": "npm version patch -m \"[🤖 Sergio Alexander Florez Galeano] New release to v%s launched 🚀\""
  },
  "dependencies": {
    "@astrojs/check": "0.9.7",
    "@astrojs/compiler-rs": "0.1.4",
    "@astrojs/mdx": "5.0.0",
    "@astrojs/rss": "4.0.17",
    "@astrojs/sitemap": "3.7.1",
    "@astrojs/svelte": "8.0.0",
    "astro": "6.0.3",
    "fuse.js": "7.1.0",
    "rehype-external-links": "3.0.0",
    "svelte": "5.53.10",
    "tailwindcss": "4.2.1",
    "typescript": "5.9.3"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.6",
    "@lhci/cli": "0.15.1",
    "@tailwindcss/typography": "0.5.19",
    "@tailwindcss/vite": "4.2.1",
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/svelte": "5.3.1",
    "@vitest/coverage-v8": "4.0.18",
    "happy-dom": "20.8.3",
    "npm-check-updates": "19.6.3",
    "sharp": "0.34.5",
    "vitest": "4.0.18"
